{
    "name": "raffaele-site",
    "version": "1.0.0",
    "description": "Personal portfolio website",
    "main": "index.html",
    "scripts": {
        "lint": "npm run lint:js && npm run lint:css && npm run lint:html",
        "lint:js": "eslint **/*.js",
        "lint:css": "stylelint **/*.css",
        "lint:html": "htmlhint **/*.html"
    },
    "keywords": [
        "portfolio"
    ],
    "author": "suppa-r",
    "license": "MIT",
    "devDependencies": {
        "eslint": "^8.57.0",
        "eslint-plugin-eslint-comments": "^3.2.0",
        "htmlhint": "^1.1.4",
        "lint-staged": "^17.0.8",
        "stylelint": "^16.3.1",
        "stylelint-config-standard": "^36.0.0"
    },
    "lint-staged": {
        "**/*.css": [
            "stylelint --fix",
            "git add"
        ],
        "**/*.{js,ts}": [
            "eslint --fix",
            "git add"
        ],
        "**/*.html": [
            "htmlhint",
            "git add"
        ]
    }
}
